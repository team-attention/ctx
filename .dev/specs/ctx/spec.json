  "context": {
    "request": "Build ctx CLI (Rust) — project context graph tool with programmatic match + semantic query. Full scope: Phase 0 (foundation) + Phase 1 (programmatic core) + Phase 2 (semantic search). Based on PRD v1.0.",
    "research": "Brand new Rust project (cargo init, hello world). TypeScript predecessor at ../ctx/ provides reference patterns but ctx-new is a full rewrite with different architecture (no registry, no global scope, triggers+depends_on graph model). PRD specifies serde_yaml, pulldown-cmark, globset, clap for CLI. No build tooling or CI configured yet. Key patterns: command-per-file structure, glob+frontmatter scanner, HashMap-based in-memory graph. Commands: cargo build/test/clippy/fmt. UX review highlights: rename setup-search to index, ctx migrate needs DRY RUN banner, ctx check consider --strict flag, omit score field for dependency nodes, add TTY-aware interactive prompts for ctx create.",
    "decisions": [
      {
        "id": "D1",
        "decision": "setup-search → index로 rename",
        "rationale": "단일동사 일관성 (init, create, list, check, match, query, show, graph, index, migrate)",
        "alternatives_rejected": [
          {
            "option": "setup-search 유지",
            "reason": "하이픈 서브커맨드는 tab completion 패턴 깨뜨림"
          }
        ]
      },
      {
        "id": "D2",
        "decision": "ctx check: 기본 exit 0, --strict 시 exit 2",
        "rationale": "&& chaining 호환성. 스크립트에서 warning으로 실패하면 안 됨",
        "alternatives_rejected": [
          {
            "option": "항상 exit 2 on warnings",
            "reason": "naive && chaining 깨뜨림"
          }
        ]
      },
      {
        "id": "D3",
        "decision": "ctx query dependency 노드에서 score 필드 생략",
        "rationale": "null보다 필드 부재가 의미 명확 (scored vs unscored)",
        "alternatives_rejected": [
          {
            "option": "score: null",
            "reason": "JSON 소비자가 null 특수처리 필요"
          }
        ]
      },
      {
        "id": "D4",
        "decision": "ctx create: TTY 감지 시 interactive prompt",
        "rationale": "새 사용자 discoverability. non-TTY는 기본값 사용",
        "alternatives_rejected": [
          {
            "option": "항상 non-interactive",
            "reason": "초보 사용자 진입장벽"
          }
        ]
      },
      {
        "id": "D5",
        "decision": "단일 spec.json에 Phase 0/1/2 전체 포함",
        "rationale": "DAG로 의존성 관리. 하나의 실행 단위",
        "alternatives_rejected": [
          {
            "option": "Phase별 별도 spec",
            "reason": "Phase간 의존성 추적 복잡"
          }
        ]
      },
      {
        "id": "D6",
        "decision": "keyword fallback에 BM25 내장",
        "rationale": "qmd 없이도 양질의 검색 품질 제공",
        "alternatives_rejected": [
          {
            "option": "simple token match",
            "reason": "검색 품질 부족"
          }
        ]
      },
      {
        "id": "D7",
        "decision": "ctx migrate --apply에 --yes 플래그 필요 (TTY시 y/N 프롬프트)",
        "rationale": "사용자 파일 변경은 HIGH risk. 이중 확인 게이트",
        "alternatives_rejected": [
          {
            "option": "--apply만으로 즉시 실행",
            "reason": "한 플래그 실수로 파일 변경 위험"
          }
        ]
      },
      {
        "id": "D8",
        "decision": "pulldown-cmark 제거, --- 문자열 split으로 frontmatter 분리",
        "rationale": "body를 raw text로만 사용. 불필요한 의존성 제거",
        "alternatives_rejected": [
          {
            "option": "pulldown-cmark 사용",
            "reason": "full CommonMark 파싱 불필요, 200KB 바이너리 증가"
          }
        ]
      },
      {
        "id": "D9",
        "decision": "ctx create interactive 모드 제거, flag-only + --help 예제 강화",
        "rationale": "dialoguer 의존성 제거, 두 코드 경로 유지보수 비용 제거",
        "alternatives_rejected": [
          {
            "option": "TTY 감지 interactive prompt",
            "reason": "의존성 추가, 테스트 복잡도 증가"
          }
        ]
      },
      {
        "id": "D10",
        "decision": "ctx check: 기본 exit 0, --strict 시 exit 2 (D2 확정)",
        "rationale": "PRD 에러 테이블 오버라이드. && chaining 호환성 우선",
        "alternatives_rejected": [
          {
            "option": "항상 exit 2 on warnings",
            "reason": "스크립트 && 체이닝 깨짐"
          }
        ]
      },
      {
        "id": "D4-SUPERSEDED",
        "decision": "D4 (ctx create interactive) 는 D9에 의해 대체됨. Interactive 모드 제거 확정",
        "rationale": "D9가 최종 결정",
        "alternatives_rejected": []
      }
    ],
